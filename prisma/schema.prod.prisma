generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ShopSetting {
  id        String   @id @default(cuid())
  shop      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rotationGroups RotationGroup[]
}

model RotationGroup {
  id                 String   @id @default(cuid())
  shop               String
  targetProductId    String
  targetProductTitle String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  shopSetting   ShopSetting  @relation(fields: [shop], references: [shop])
  rotationItems RotationItem[]
  instances     SubscriptionInstance[]

  @@unique([shop, targetProductId])
  @@index([shop])
}

model RotationItem {
  id              String   @id @default(cuid())
  rotationGroupId String
  productId       String
  variantId       String
  productTitle    String
  variantTitle    String?
  sortOrder       Int
  isActive        Boolean  @default(true)
  imageUrl        String?
  price           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rotationGroup RotationGroup @relation(fields: [rotationGroupId], references: [id], onDelete: Cascade)

  @@index([rotationGroupId])
  @@index([rotationGroupId, sortOrder])
}

model SubscriptionInstance {
  id                     String    @id @default(cuid())
  shop                   String
  customerId             String
  originalOrderId        String
  originalLineItemIds    Json
  subscriptionContractId String?
  targetProductId        String
  currentIndex           Int       @default(0)
  uniqueKey              String    @unique
  status                 String    @default("ACTIVE")
  lineItemSnapshot       Json
  rotationGroupId        String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  rotationGroup RotationGroup @relation(fields: [rotationGroupId], references: [id])
  rotationLogs  RotationLog[]

  @@index([shop])
  @@index([shop, customerId])
  @@index([shop, targetProductId])
  @@index([shop, subscriptionContractId])
}

model RotationLog {
  id                     String   @id @default(cuid())
  shop                   String
  orderId                String
  subscriptionInstanceId String
  fromProductId          String?
  fromProductTitle       String?
  toProductId            String
  toProductTitle         String
  rotationIndex          Int
  status                 String   @default("SUCCESS")
  errorMessage           String?
  triggeredBy            String   @default("WEBHOOK")
  rotatedAt              DateTime @default(now())

  subscriptionInstance SubscriptionInstance @relation(fields: [subscriptionInstanceId], references: [id], onDelete: Cascade)

  @@index([shop])
  @@index([subscriptionInstanceId])
  @@index([shop, rotatedAt])
}
